{
	"compilerOptions": {
		"target": "ES2022",
		"baseUrl": ".",
		"module": "ES2022",
		"moduleResolution": "Bundler",

		"types": ["foundry-pf2e/foundry"],

		"strict": false,
		"strictNullChecks": true,
		"sourceMap": true,
		"forceConsistentCasingInFileNames": true,
		"isolatedModules": true,

		"verbatimModuleSyntax": true
	},

	"include": ["src/**/*"],
	"exclude": ["node_modules/*"]
}
